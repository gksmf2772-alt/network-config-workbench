{
  "name": "network-config-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "node --test tests/*.test.js",
    "validate:inventory": "node scripts/validate-inventory.mjs",
    "validate:compare": "node scripts/validate-compare-workflows.mjs --mode compare",
    "validate:audit": "node scripts/validate-compare-workflows.mjs --mode audit",
    "validate:report": "node scripts/validate-compare-workflows.mjs --mode report",
    "validate:graph": "node scripts/validate-compare-workflows.mjs --mode graph",
    "validate:quality": "node scripts/analyze-validation-quality.mjs",
    "validate:profile-exceptions": "node scripts/validate-profile-exceptions.mjs",
    "validate:object-review": "node scripts/validate-object-review-grouping.mjs",
